  "scoring_tests": [
    {"test_id": "ST-01", "name": "TrackMan Combine (60-shot)", "diagnostic_purpose": "Overall ball striking benchmark", "protocol": "3 shots × 10 targets × 2 rounds; 10-15min warmup first", "targets_yds": [60,70,80,90,100,120,140,160,180,"driver"], "scoring": "0-100 per shot; 100-circle = ~2.2% of target distance", "pass_criteria": {"tour_pro": 83, "5hcp": 67, "15hcp": 50, "improvement_vs_baseline": "any positive delta"}, "fail_action": "Investigate weakest distance window; assign DF-11 or primary fault DF", "retest_frequency": "monthly", "maps_to_branch_intents": ["BI-03","BI-04","BI-07"], "technology_required": "trackman_combine_mode", "evidence_tag": "evidence_supported", "source": "FSGA TrackMan Combine benchmarks"},
