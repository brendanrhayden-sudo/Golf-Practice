    {"test_id": "ST-08", "name": "CHS Baseline (Speed)", "diagnostic_purpose": "Speed training progress (BI-05)", "protocol": "5 maximum-effort no-ball swings driver; record peak CHS", "pass_criteria": {"improvement_4wk": ">= 3-5% from baseline"}, "fail_action": "Check protocol compliance; check mobility gates; rest day", "retest_frequency": "weekly_gp02", "technology_required": "trackman_noball_or_prgr", "evidence_tag": "evidence_supported"},
    {"test_id": "ST-12", "name": "SAM PuttLab Assessment (10 putts)", "diagnostic_purpose": "Putting stroke mechanics baseline (BI-08)", "protocol": "10 putts × 4m straight; player's own putter; full pre-shot routine", "metrics": ["face_at_address","face_at_impact","path_at_impact","face_on_path","rise_angle","stroke_type","tempo_ratio"], "pass_criteria": {"face_at_impact_sd_deg": "< 1.0", "tempo_ratio": "2.0-2.4"}, "fail_action": "DC-019 gate drill for face; DC-048 rhythm for tempo", "retest_frequency": "monthly", "technology_required": "sam_puttlab", "evidence_tag": "evidence_supported", "source": "SAM PuttLab PGA Tour n=150 data"},
