  "branch_intents": [
    {"intent_id": "BI-01", "name": "Face Angle Control", "description": "Inconsistent or biased face angle; two-way miss or directional error", "trackman_triggers": [{"metric": "FAC_ANG_SD", "op": ">", "value": 2.0, "unit": "degrees"}, {"metric": "two_way_miss", "op": "==", "value": true}], "sportsbox_triggers": [{"metric": "chest_turn_imp", "op": "< 15 OR > 40"}], "proof_test_id": "ST-03", "drill_families_primary": ["DF-01","DF-03","DF-05","DF-20"], "blocks_required": [4,5,6,7,8,10], "tech_required": ["trackman"], "tech_optional": ["hackmotion","sportsbox"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-02", "name": "Club Path Shape", "description": "Consistent path bias OTI or ITI; curvature mismatch", "trackman_triggers": [{"metric": "CLB_PTH_mean", "op": "> 3 or < -3", "unit": "degrees"}, {"metric": "CRV_bias", "op": "present"}], "sportsbox_triggers": [{"metric": "pelvis_turn_imp", "op": "< 25", "unit": "degrees_open"}], "proof_test_id": "ST-04", "drill_families_primary": ["DF-02","DF-03","DF-06"], "blocks_required": [4,5,6,7,8,10], "tech_required": ["trackman"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-03", "name": "Attack Angle / Low Point", "description": "Fat/thin pattern; ATK_ANG too negative with irons; LOW_PT before ball", "trackman_triggers": [{"metric": "ATK_ANG", "op": "< -5", "unit": "degrees", "club": "irons"}, {"metric": "LOW_PT", "op": "before_ball"}], "sportsbox_triggers": [{"metric": "pelvis_thrust_imp", "op": "> 2", "unit": "inches"}, {"metric": "sway_gap_imp", "op": "< -1"}], "proof_test_id": "ST-05", "drill_families_primary": ["DF-04","DF-07"], "blocks_required": [4,5,6,7,8,10], "tech_required": ["trackman"], "tech_optional": ["sportsbox","video"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-04", "name": "Strike Quality / Smash Factor", "description": "Low smash factor; inconsistent contact; Spin Axis mismatch from gear effect", "trackman_triggers": [{"metric": "SMSH", "op": "< 1.43", "club": "driver"}, {"metric": "SMSH", "op": "< 1.28", "club": "irons"}, {"metric": "SMSH_SD", "op": "> 0.02"}], "proof_test_id": "ST-06", "drill_families_primary": ["DF-01"], "drill_families_secondary": ["DF-03"], "blocks_required": [4,5,6,7,8,10], "tech_required": ["trackman"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-05", "name": "Speed / Distance", "description": "CHS below level-appropriate benchmark; kinematic sequence power leak", "trackman_triggers": [{"metric": "CLB_SPD", "op": "< level_benchmark"}], "sportsbox_triggers": [{"metric": "core_gain_factor", "op": "< 1.3"}, {"metric": "kinematic_sequence_order", "op": "error"}], "proof_test_id": "ST-08", "drill_families_primary": ["DF-09","DF-10"], "blocks_required": [2,3,4,5,9,10], "blocks_forbidden": [7,8], "conflict_gates": ["GP-06_acquisition_active"], "tech_required": ["trackman_noball_or_prgr"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-06", "name": "Launch Conditions (Driver)", "description": "Driver launch outside Optimizer window; spin loft >16°; distance deficit despite CHS", "trackman_triggers": [{"metric": "launch_angle", "op": "outside_optimizer_window"}, {"metric": "SPN_LFT", "op": "> 16", "club": "driver"}], "proof_test_id": "ST-07", "drill_families_primary": ["DF-04"], "equipment_flag": "may_be_equipment_not_technique_if_smash_gte_146", "tech_required": ["trackman_optimizer"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-07", "name": "Distance Control (Wedge)", "description": "Wedge carry SD >5 yds at target distances; gap inconsistency", "trackman_triggers": [{"metric": "CARRY_SD", "op": "> 5", "club": "wedges"}], "proof_test_id": "ST-09", "drill_families_primary": ["DF-11"], "tech_required": ["trackman"], "evidence_tag": "expert_framework"},
    {"intent_id": "BI-08", "name": "Putting Direction", "description": "Face angle SD >1° at impact; two-way miss putting", "sam_puttlab_triggers": [{"metric": "face_at_impact_SD", "op": "> 1.0"}], "proof_test_id": "ST-12", "drill_families_primary": ["DF-12"], "tech_required": ["sam_puttlab_or_blast_motion"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-09", "name": "Putting Speed Control", "description": "Entry speed variability; stimp mismatch; roll percentage inconsistency", "sam_puttlab_triggers": [{"metric": "entry_speed_SD", "op": "high"}, {"metric": "stimp_mismatch", "op": "present"}], "proof_test_id": "ST-14", "drill_families_primary": ["DF-13"], "tech_optional": ["sam_puttlab"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-10", "name": "Kinematic Sequence", "description": "Segment sequencing errors; gain factor deficits; over-the-top pattern", "sportsbox_triggers": [{"metric": "kinematic_sequence_order", "op": "error"}, {"metric": "core_gain_factor", "op": "< 1.3"}], "proof_test_id": "ST-15", "drill_families_primary": ["DF-06","DF-07","DF-08"], "tech_required": ["sportsbox_3d"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-11", "name": "GRF / Pressure Shift", "description": "Late or absent lead-side pressure shift; no braking force at impact", "force_plate_triggers": [{"metric": "lead_foot_pct_impact", "op": "< 70"}, {"metric": "pressure_shift_timing", "op": "at_or_after_impact"}], "sportsbox_triggers": [{"metric": "pelvis_sway_imp", "op": "< 2 or > 6", "unit": "inches"}], "proof_test_id": "ST-16", "drill_families_primary": ["DF-07"], "tech_required": ["force_plate_or_sportsbox"], "evidence_tag": "evidence_supported"},
    {"intent_id": "BI-12", "name": "Short Game — Chipping", "description": "Low point inconsistency from short distances; proximity >5ft average", "proof_test_id": "ST-20", "drill_families_primary": ["DF-15","DF-17"], "tech_optional": ["trackman","video"], "evidence_tag": "expert_framework"},
    {"intent_id": "BI-13", "name": "Short Game — Bunker", "description": "Exit rate <80%; fat/thin from sand; inconsistent splash zone", "proof_test_id": "ST-21", "drill_families_primary": ["DF-16"], "tech_optional": ["video"], "evidence_tag": "expert_framework"},
    {"intent_id": "BI-14", "name": "Course Management", "description": "Penalty strokes >1.5/round; poor decision quality score; bogey avoidance <target", "diagnostic_source": ["gip_round_stats","decade_audit"], "proof_test_id": "ST-22", "drill_families_primary": ["DF-18","DF-19"], "blocks_required": [1,8,11], "blocks_forbidden": [4,5,6,7], "evidence_tag": "expert_framework"},
    {"intent_id": "BI-15", "name": "Wrist / Shaft Control", "description": "F2P inconsistency without structural path or face cause; Spin Axis bias from wrist flip", "hackmotion_triggers": [{"metric": "lead_wrist_angle_p5", "op": "outside_window_neg5_to_pos5"}], "proof_test_id": "ST-17", "drill_families_primary": ["DF-20"], "tech_required": ["hackmotion"], "evidence_tag": "expert_framework"}
