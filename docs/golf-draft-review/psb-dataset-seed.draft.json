    {"test_id": "ST-18", "name": "TPI 16-Point Screen", "diagnostic_purpose": "Physical limitation mapping for all branch intents", "protocol": "Full 16-test TPI screen; score pass/fail per test; pain = zero = refer first", "pass_criteria": "all_pass", "fail_action": "Targeted corrective; pink elephant priority; DC-027/028/029", "retest_frequency": "quarterly", "technology_required": "none_goniometer_helpful", "evidence_tag": "evidence_supported", "source": "TPI 100,000+ golfer database"},
